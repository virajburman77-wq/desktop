           *[other] { $tabCount } Sekmeyi sıfırla ve sabitle
        }
zen-tab-sublabel =
    { $tabSubtitle ->
        [zen-default-pinned] Sabitlenmiş URL’ye geri dön
        [zen-default-pinned-cmd] Sabitlenmiş sekmeden ayır
       *[other] { $tabSubtitle }
    }
